/**
 * HNH Portal — SPA page server
 * Clean version with no escaping issues
 */
export function servePage(req) {
  const url = new URL(req.url);
  const lang = url.searchParams.get('lang') || 'ar';
  const isAr = lang === 'ar';
  const L = lang;
  const A = isAr;
  const dir = A ? 'rtl' : 'ltr';

  const tFn = `const L = '${L}', A = L === 'ar';
const API = location.origin;
const t = (ar, en) => A ? ar : en;
const es = s => { const d = document.createElement('div'); d.appendChild(document.createTextNode(s)); return d.innerHTML; };`;

  // Build HTML as JS template
  let html = `<!DOCTYPE html>
<html lang="${L}" dir="${dir}">
<head>
<meta charset="utf-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1"/>
<title>${A ? 'مستشفى الحياة الوطني | HNH Portal' : 'Hayat National Hospital | HNH Portal'}</title>
<meta name="description" content="Patient portal powered by BrainSAIT Healthcare OS">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Noto+Kufi+Arabic:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
*{margin:0;padding:0;box-sizing:border-box}
:root{--bg:#0f172a;--bg2:#1e293b;--bg3:#334155;--t:#f8fafc;--t2:#94a3b8;--t3:#64748b;--c1:#0891b2;--c2:#059669;--c3:#7c3aed;--c4:#d97706;--c5:#dc2626;--r:12px;--rs:8px}
html{font-family:${A ? 'Noto Kufi Arabic, sans-serif' : 'Inter, sans-serif'};background:var(--bg);color:var(--t)}
body{min-height:100vh;display:flex;flex-direction:column}
input,select,textarea,button{font-family:inherit;font-size:14px;background:var(--bg2);border:1px solid var(--bg3);color:var(--t);padding:10px 14px;border-radius:var(--rs);width:100%;outline:none;transition:.2s}
input:focus,select:focus,textarea:focus{border-color:var(--c1);box-shadow:0 0 0 2px rgba(8,145,178,.2)}
.hdr{background:linear-gradient(135deg,#0f172a,#1e293b);padding:0 20px;height:60px;display:flex;align-items:center;justify-content:space-between;border-bottom:1px solid rgba(255,255,255,.06);position:sticky;top:0;z-index:100}
.hl{display:flex;align-items:center;gap:10px}
.ico{width:34px;height:34px;border-radius:10px;background:rgba(8,145,178,.15);display:flex;align-items:center;justify-content:center;font-size:18px;color:var(--c1)}
.ht h1{font-size:15px;font-weight:600;color:var(--t)}
.ht p{font-size:10px;color:var(--t3)}
.hr{display:flex;align-items:center;gap:8px}
.nav{display:flex;gap:2px}
.nv{padding:6px 12px;border-radius:8px;font-size:13px;color:var(--t2);cursor:pointer;transition:.2s;white-space:nowrap}
.nv:hover,.nv.a{background:rgba(255,255,255,.08);color:var(--t)}
.lb,.mb{padding:6px 12px;border-radius:8px;font-size:12px;background:rgba(255,255,255,.06);color:var(--t2);cursor:pointer;border:none}
.mb{display:none;font-size:20px}
.mn{flex:1;max-width:1200px;margin:0 auto;padding:24px;width:100%}
.hro{border-radius:var(--r);padding:32px;margin-bottom:24px;background:linear-gradient(135deg,#0f172a,#1e293b,#0f172a);position:relative;overflow:hidden}
.hro:before{content:"";position:absolute;inset:0;opacity:.03;background:radial-gradient(circle at 25% 50%,rgba(8,145,178,.4),transparent 50%),radial-gradient(circle at 75% 50%,rgba(34,211,238,.2),transparent 50%)}
.hc{position:relative}.hd{font-size:12px;color:var(--t3);margin-bottom:4px}
.ht2{font-size:24px;font-weight:700;margin-bottom:4px;color:var(--t)}
.hs{color:var(--t2);font-size:14px}
.cg{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:14px;margin-bottom:24px}
.sc{padding:20px;border-radius:var(--r);background:var(--bg2);border:1px solid rgba(255,255,255,.06);text-align:center}
.sn{font-size:28px;font-weight:700;margin-bottom:4px}
.sl{font-size:13px;color:var(--t2)}
.qg{display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));gap:10px;margin-bottom:24px}
.qc{background:var(--bg2);border-radius:var(--r);padding:16px;text-align:center;border:1px solid rgba(255,255,255,.06);cursor:pointer;transition:.2s}
.qc:hover{transform:scale(1.03);border-color:rgba(8,145,178,.3)}
.qi{width:40px;height:40px;border-radius:12px;display:flex;align-items:center;justify-content:center;margin:0 auto 8px;font-size:20px}
.ql{font-size:13px;font-weight:500;color:var(--t)}
.dg{display:grid;grid-template-columns:repeat(auto-fill,minmax(120px,1fr));gap:8px;margin-bottom:24px}
.dc{background:var(--bg2);border-radius:var(--rs);padding:12px;text-align:center;border:1px solid rgba(255,255,255,.06);font-size:13px;color:var(--t)}
.st{font-size:16px;font-weight:600;margin-bottom:14px;display:flex;align-items:center;gap:8px;color:var(--t)}
.st span{font-size:11px;color:var(--t3);font-weight:400}
.ft{text-align:center;padding:20px;border-top:1px solid rgba(255,255,255,.06);font-size:11px;color:var(--t3)}
.ft .bn{color:var(--c1);font-weight:600}
.ld{padding:40px;text-align:center;color:var(--t2)}
@media(max-width:768px){
  .nav{display:none;position:absolute;top:60px;${A ? 'right' : 'left'}:0;width:100%;background:var(--bg);flex-direction:column;padding:8px;border-bottom:1px solid rgba(255,255,255,.06)}
  .nav.o{display:flex}.mb{display:block}
  .ht2{font-size:20px}.sn{font-size:22px}.qg{grid-template-columns:repeat(2,1fr)}.cg{grid-template-columns:1fr 1fr}
}
</style>
</head>
<body>
<div class="hdr">
  <div class="hl"><div class="ico">&x1F3E5;</div><div class="ht"><h1>${A ? 'مستشفى الحياة الوطني' : 'Hayat National Hospital'}</h1><p>${A ? 'بوابة خدمات المرضى' : 'Patient Portal'}</p></div></div>
  <div class="hr">
    <nav class="nav" id="nv">
      <div class="nv a" data-p="dashboard">${A ? 'الرئيسية' : 'Home'}</div>
      <div class="nv" data-p="branches">${A ? 'الفروع' : 'Branches'}</div>
      <div class="nv" data-p="appointments">${A ? 'المواعيد' : 'Appts'}</div>
      <div class="nv" data-p="providers">${A ? 'الأطباء' : 'Doctors'}</div>
      <div class="nv" data-p="claims">${A ? 'المطالبات' : 'Claims'}</div>
    </nav>
    <button class="lb" id="lb">${A ? 'EN' : 'العربية'}</button>
    <button class="mb" id="mb">&#x2630;</button>
  </div>
</div>
<main class="mn" id="app"><div class="ld">${A ? 'جاري التحميل...' : 'Loading...'}</div></main>
<footer class="ft"><p>${A ? 'مشغل بـ' : 'Powered by'} <span class="bn">BrainSAIT Healthcare OS</span></p>
<p style="font-size:10px;margin-top:4px;color:var(--t3)">&#x00A9; 2026 Hayat National Hospitals</p></footer>
<script>
${tFn}
window.API = location.origin;
window._L = L;
window._A = A;

// Reusable helper to update page
window.loadPage = async function(pageId) {
  const app = document.getElementById("app");
  app.innerHTML = "<div class=ld>"+t("جاري التحميل...", "Loading...")+"</div>";
  document.querySelectorAll(".nv").forEach(n => n.classList.remove("a"));
  const el = document.querySelector('[data-p="'+pageId+'"]');
  if (el) el.classList.add("a");
  try {
    switch(pageId) {
      case "dashboard": app.innerHTML = await renderDashboard(); break;
      case "branches": app.innerHTML = await renderBranches(); break;
      case "appointments": app.innerHTML = await renderAppointments(); break;
      case "providers": app.innerHTML = await renderProviders(); break;
      case "claims": app.innerHTML = await renderClaims(); break;
      default: app.innerHTML = await renderDashboard();
    }
  } catch(e) {
    app.innerHTML = "<p style='padding:40px;text-align:center;color:var(--t3)'>"+t("خطأ", "Error")+"</p>";
  }
};

// Dashboard
async function renderDashboard() {
  let s = {total_patients:0,today_appointments:0,total_providers:12,total_departments:16,total_claims:0};
  try { const r = await fetch(API+"/api/stats"); const d = await r.json(); if(d.success) s = d.stats; } catch(e) {}
  return [
    '<div class=hro><div class=hc><p class=hd>'+t("الخميس","Thu")+'</p><h2 class=ht2>'+t("مرحباً بكم في مستشفى الحياة الوطني","Welcome to Hayat National Hospital")+'</h2><p class=hs>'+t("بوابة خدمات المرضى","Patient Portal")+'</p></div></div>',
    '<div class=cg>',
      '<div class=sc style="border-color:rgba(8,145,178,.2)"><div class=sn style="color:var(--c1)">'+s.total_patients+'</div><div class=sl>'+t("المرضى","Patients")+'</div></div>',
      '<div class=sc style="border-color:rgba(5,150,105,.2)"><div class=sn style="color:var(--c2)">'+s.today_appointments+'</div><div class=sl>'+t("مواعيد اليوم","Appts Today")+'</div></div>',
      '<div class=sc style="border-color:rgba(124,58,237,.2)"><div class=sn style="color:var(--c3)">'+s.total_providers+'</div><div class=sl>'+t("الأطباء","Doctors")+'</div></div>',
      '<div class=sc style="border-color:rgba(217,119,6,.2)"><div class=sn style="color:var(--c4)">'+s.total_departments+'</div><div class=sl>'+t("الأقسام","Departments")+'</div></div>',
      '<div class=sc style="border-color:rgba(220,38,38,.2)"><div class=sn style="color:var(--c5)">'+s.total_claims+'</div><div class=sl>'+t("المطالبات","Claims")+'</div></div>',
    '</div>',
    '<div class=st>'+t("خدمات سريعة","Quick Actions")+'</div>',
    '<div class=qg>',
      '<div class=qc onclick="loadPage(&apos;appointments&apos;)"><div class=qi style="background:rgba(8,145,178,.1);color:var(--c1)">📅</div><div class=ql>'+t("حجز موعد","Book Appt.")+'</div></div>',
      '<div class=qc onclick="alert(&apos;'+t("قريباً","Coming soon")+'&apos;)"><div class=qi style="background:rgba(5,150,105,.1);color:var(--c2)">👤</div><div class=ql>'+t("تسجيل مريض","Register")+'</div></div>',
      '<div class=qc onclick="loadPage(&apos;providers&apos;)"><div class=qi style="background:rgba(124,58,237,.1);color:var(--c3)">🩺</div><div class=ql>'+t("بحث عن طبيب","Find Dr.")+'</div></div>',
      '<div class=qc onclick="loadPage(&apos;claims&apos;)"><div class=qi style="background:rgba(217,119,6,.1);color:var(--c4)">📋</div><div class=ql>'+t("مطالبة","Claim")+'</div></div>',
      '<div class=qc onclick="loadPage(&apos;branches&apos;)"><div class=qi style="background:rgba(220,38,38,.1);color:var(--c5)">🏥</div><div class=ql>'+t("الفروع","Branches")+'</div></div>',
    '</div>',
    '<div class=st>'+t("الأقسام الطبية","Departments")+'</div>',
    '<div class=dg>'+["طوارئ","باطنية","جراحة","عظام","أطفال","نساء","قلب","جلدية","أسنان","عيون","مسالك","أعصاب","نفسي","مختبر","أشعة","صيدلة"].map(d=>"<div class=dc>"+d+"</div>").join("")+'</div>',
  ].join("\\n");
}

// Branches
async function renderBranches() {
  let br = [];
  try { const r = await fetch(API+"/api/branches"); const d = await r.json(); if(d.success) br = d.branches; }catch(e){}
  return [
    '<div class=st>'+t("الفروع","Branches")+' <span>7</span></div>',
    br.map(b => '<div class=brc style="background:var(--bg2);border-radius:var(--r);padding:20px;border:1px solid rgba(255,255,255,.06);margin-bottom:10px"><h3 style="font-size:15px;color:var(--t)">'+(A?b.name_ar:b.name_en)+'</h3><p style="font-size:13px;color:var(--t2)">'+b.phone+'</p><p style="font-size:13px;color:var(--t2)">'+b.email+'</p></div>').join(""),
  ].join("\\n");
}

// Appointments
async function renderAppointments() {
  let r;
  try { r = await fetch(API+"/api/appointments?limit=50"); r = await r.json(); }catch(e){}
  const rows = (r && r.success && r.appointments) 
    ? r.appointments.map(a => "<tr><td>"+(a.patient_name_ar||"--")+"</td><td>"+a.appointment_date+"</td><td>"+a.appointment_time+"</td><td>"+a.status+"</td></tr>").join("")
    : "<tr><td colspan=4 style='text-align:center;padding:20px;color:var(--t3)'>"+t("لا توجد مواعيد","No appointments")+"</td></tr>";
  return [
    '<div class=st>📅 '+t("المواعيد","Appointments")+'</div>',
    '<div class=tw style="overflow-x:auto;background:var(--bg2);border-radius:var(--r);border:1px solid rgba(255,255,255,.06)">',
    '<table style="width:100%;border-collapse:collapse;font-size:13px"><thead><tr>',
    "<th style='padding:10px 14px;color:var(--t2);border-bottom:1px solid rgba(255,255,255,.08);text-align:${A?"right":"left"}'>"+t("المريض","Patient")+"</th>",
    "<th>"+t("التاريخ","Date")+"</th><th>"+t("الوقت","Time")+"</th><th>"+t("الحالة","Status")+"</th>",
    "</tr></thead><tbody>"+rows+"</tbody></table></div>",
  ].join("\\n");
}

// Providers
async function renderProviders() {
  let r;
  try { r = await fetch(API+"/api/providers"); r = await r.json(); }catch(e){}
  if (!r || !r.success) return "<p style='padding:20px;color:var(--t3)'>"+t("لا يوجد أطباء","No doctors")+"</p>";
  return [
    '<div class=st>🩺 '+t("الأطباء","Doctors")+' <span>'+r.providers.length+'</span></div>',
    r.providers.map(p => 
      '<div style="display:flex;gap:16px;align-items:start;padding:16px;background:var(--bg2);border-radius:var(--r);border:1px solid rgba(255,255,255,.06);margin-bottom:10px">'+
      '<div style="width:48px;height:48px;border-radius:50%;background:linear-gradient(135deg,var(--c1),var(--c3));display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0">👨‍⚕️</div>'+
      '<div style="flex:1"><h4 style="font-size:14px;color:var(--t)">'+(A?p.name_ar:p.name_en)+'</h4>'+
      '<p style="font-size:12px;color:var(--t2)">'+(A?p.specializations.join(", "):p.specializations_en.join(", "))+'</p>'+
      '<p style="font-size:11px;color:var(--t3);margin-top:4px">⭐ '+p.rating+' | '+p.experience_years+' '+t("سنة","years")+'</p></div></div>'
    ).join(""),
  ].join("\\n");
}

// Claims
async function renderClaims() {
  let r;
  try { r = await fetch(API+"/api/claims?limit=50"); r = await r.json(); }catch(e){}
  const rows = (r && r.success && r.claims) 
    ? r.claims.map(c => "<tr><td>"+c.claim_number+"</td><td>"+c.total_amount+"</td><td>"+c.status+"</td><td>"+(c.nphies_status||"-")+"</td></tr>").join("")
    : "<tr><td colspan=4 style='text-align:center;padding:20px;color:var(--t3)'>"+t("لا توجد مطالبات","No claims")+"</td></tr>";
  return [
    '<div class=st>📋 '+t("المطالبات","Claims")+' <span>NPHIES</span></div>',
    '<div class=tw><table style="width:100%;border-collapse:collapse;font-size:13px"><thead><tr>',
    "<th>"+t("الرقم","Claim#")+"</th><th>"+t("المبلغ","Amount")+"</th><th>"+t("الحالة","Status")+"</th><th>NPHIES</th>",
    "</tr></thead><tbody>"+rows+"</tbody></table></div>",
  ].join("\\n");
}

// Nav clicks
document.querySelectorAll("[data-p]").forEach(el => el.addEventListener("click", () => loadPage(el.dataset.p)));
document.getElementById("mb").addEventListener("click", () => document.getElementById("nv").classList.toggle("o"));
document.getElementById("lb").addEventListener("click", () => { window.location.href = window.location.pathname + "?lang=" + (A ? "en" : "ar"); });

// Load dashboard
loadPage("dashboard");
</script>
</body>
</html>`;

  return html;
}
